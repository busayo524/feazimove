# ─── FeaziMove API — Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in real values. NEVER commit .env to git.

# Server
PORT=4000
NODE_ENV=production

# Database (Neon Postgres) — get from https://console.neon.tech
DATABASE_URL=postgresql://USER:PASSWORD@YOUR-NEON-HOST.aws.neon.tech/neondb?sslmode=require

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# (access-token lifetime is fixed at 15m in code; refresh tokens last 30 days)
JWT_SECRET=replace_with_a_long_random_secret_at_least_64_chars

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://feazimove.com,https://www.feazimove.com

# Base URL used in emails and payment redirects — the site lives under /app/
APP_URL=https://www.feazimove.com/app

# SMTP (Zoho Mail) — transactional email
SMTP_HOST=smtppro.zoho.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=you@yourdomain.com
SMTP_PASS=your_smtp_password_here
SMTP_FROM=FeaziMove <you@yourdomain.com>

# Google OAuth (optional — enables "Sign in with Google")
GOOGLE_CLIENT_ID=your_google_client_id_here

# Prembly (optional — enables identity verification)
PREMBLY_API_KEY=your_prembly_api_key_here
PREMBLY_APP_ID=your_prembly_app_id_here

# Anchor (getanchor.co) banking rails
ANCHOR_BASE_URL=https://api.sandbox.getanchor.co
ANCHOR_API_KEY=your_anchor_api_key
ANCHOR_WEBHOOK_TOKEN=random_shared_secret_also_pasted_in_anchor_webhook_form
ANCHOR_PROVIDER=ninepsb
# ANCHOR_MASTER_ACCOUNT_ID=  # optional — else the root deposit account is auto-detected

# Analytics (optional) — server-side Mixpanel events
MIXPANEL_TOKEN=your_mixpanel_project_token

# AML monitoring thresholds (optional — defaults shown; amounts in kobo)
# AML_LARGE_TOPUP_KOBO=20000000       # flag any single top-up ≥ ₦200,000
# AML_RAPID_TOPUP_COUNT=5             # flag > N gateway top-ups per 24h
# AML_WEEKLY_VOLUME_KOBO=100000000    # flag ≥ ₦1,000,000 funded per 7 days
# AML_FAST_OUT_MINUTES=60             # flag payout requested within N min of funding
